# Database
DATABASE_URL=

# Customer magic-link sessions (separate from OPS_SESSION)
CUSTOMER_SESSION_SECRET=
# Optional extra entropy mixed into HMAC key material
CUSTOMER_SESSION_PEPPER=

# Public base URL for magic links (fallback: NEXT_PUBLIC_SITE_URL)
AUTH_PUBLIC_BASE_URL=
NEXT_PUBLIC_SITE_URL=

# Resend (server-only — never expose RESEND_API_KEY client-side)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Ops console session + bootstrap admin (password via OPS_ADMIN_PASSWORD_HASH)
OPS_SESSION_SECRET=
OPS_ADMIN_EMAIL=
OPS_ADMIN_PASSWORD_HASH=
# Comma-separated extra emails allowed to use password step at /login
OPS_PASSWORD_LOGIN_EMAILS=

# Internal APIs
INTERNAL_API_SECRET=
