# Copy to .env or .env.production on the server (never commit real secrets).

# Prisma + PostgreSQL
DATABASE_URL="postgresql://momos_user:CHANGE_ME@127.0.0.1:5432/momos_prod"

# Square (server + client)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
# Optional alias if your deploy docs use APP_ID — code accepts either name
# NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production

# Carrier quotes + labels (server only — never expose keys client-side)
# SHIPPO_ENV mirrors whether your token is sandbox/test vs production/live (documentation / sanity checks only).
SHIPPO_API_KEY=
SHIPPO_ENV=sandbox
# Ship-from warehouse (required for checkout delivery quotes)
SHIPPO_FROM_STREET=
SHIPPO_FROM_CITY=
SHIPPO_FROM_STATE=
SHIPPO_FROM_ZIP=
SHIPPO_FROM_COUNTRY=US
# Optional but recommended for accurate quotes / carrier rules
# SHIPPO_FROM_NAME=Momo's Ship Desk
# SHIPPO_FROM_PHONE=+15555550123

# Optional: Next binds PORT; must match ecosystem.config.cjs and nginx proxy_pass
# PORT=3000
