# Example nginx site for Momo's Next.js behind reverse proxy.
# 1. Copy to /etc/nginx/sites-available/momos (adjust server_name).
# 2. sudo ln -s /etc/nginx/sites-available/momos /etc/nginx/sites-enabled/
# 3. sudo nginx -t && sudo systemctl reload nginx
# 4. sudo certbot --nginx -d momos.example.com
#
# PM2/next start must listen on 127.0.0.1:3000 (see ecosystem.config.cjs PORT).

server {
    listen 80;
    server_name momos.example.com;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
