generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminSettings {
  id        String   @id @default("default")
  data      Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admin_settings")
}

/**
 * Centralized storefront availability flags.
 *
 * **`enabled: true`** ⇒ surface is **open** (browse + guarded checkout APIs allowed).
 * **`enabled: false`** ⇒ **maintenance** (overlay + 403 on matching cart/order flows).
 * This deliberately inverts confusing PowerApps-style “Yes = maintenance on” toggles: the row id describes
 * the feature (`ShopEnabled`, `MenuEnabled`) and the column means that feature is available.
 */
model AppSetting {
  settingId   String   @id @map("setting_id")
  enabled     Boolean
  description String?
  lastUpdated DateTime @updatedAt @map("last_updated") @db.Timestamptz(6)
  updatedBy   String?  @map("updated_by")

  @@map("app_settings")
}

/** Governance-visible platform switches; keyed by definitions in `lib/platform/governanceFeatures`. */
model PlatformFeatureToggle {
  key       String   @id
  enabled   Boolean
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?  @map("updated_by")

  @@map("platform_feature_toggles")
}

/**
 * Super-admin operational kill switches — keyed by `lib/governance/controlKeys.ts`.
 * When `enabled` is true, the named restriction is active (e.g. checkout_disabled ⇒ checkout APIs return 403).
 */
model PlatformGovernanceControl {
  id               String   @id @default(cuid())
  key              String   @unique
  category         String
  enabled          Boolean  @default(false)
  value            Json?
  description      String?
  lastModifiedBy   String?  @map("last_modified_by")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  metadata         Json?

  @@map("platform_governance_controls")
}

model CafeOrder {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart              Json
  customer          Json
  totalCents        Int       @map("total_cents")
  fulfillmentType   String    @default("PICKUP") @map("fulfillment_type")
  scheduledFor      DateTime? @map("scheduled_for") @db.Timestamptz(6)
  estimatedPickupAt DateTime? @map("estimated_pickup_at") @db.Timestamptz(6)
  status            String
  isPaid            Boolean   @default(false) @map("is_paid")
  squarePaymentId   String?   @map("square_payment_id")
  squareOrderId     String?   @map("square_order_id")
  notes             String?

  @@index([createdAt(sort: Desc)], map: "cafe_orders_created_at_idx")
  @@index([status], map: "cafe_orders_status_idx")
  @@map("cafe_orders")
}

enum CateringInquiryStatus {
  new
  contacted
  quoted
  booked
  closed
  failed_submission
}

model CateringInquiry {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  email            String
  phone            String
  eventDate        String               @map("event_date")
  guestCount       Int                  @map("guest_count")
  eventType        String?              @map("event_type")
  details          String?
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  status           CateringInquiryStatus @default(new) @map("status")
  assignedTo       String?              @map("assigned_to")
  lastFollowUpAt   DateTime?            @map("last_follow_up_at") @db.Timestamptz(6)
  internalNotes    String?              @map("internal_notes") @db.Text
  submissionError  String?              @map("submission_error") @db.Text
  contactedAt      DateTime?            @map("contacted_at") @db.Timestamptz(6)

  @@index([status], map: "catering_inquiries_status_idx")
  @@map("catering_inquiries")
}

/// Guest / future Clerk-linked profile — cafe_orders remain separate until unified checkout migrates.
model Customer {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  email                String?  @unique
  phone                String?
  externalAuthSubject  String?  @unique @map("external_auth_subject")
  squareCustomerId     String?  @map("square_customer_id")
  /// Clerk / future auth hints, guest-merge markers — never store passwords here.
  authMetadata         Json?    @map("auth_metadata")

  cartSessions      CartSession[]
  orders            CommerceOrder[]
  addresses         ShippingAddress[]
  emailThreads      EmailThread[]
  conversationLinks ConversationParticipant[]

  @@map("customers")
}

model CartSession {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  guestToken  String?   @unique @map("guest_token")
  customerId  String?   @map("customer_id") @db.Uuid
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)

  items             CartItem[]
  shippingAddresses ShippingAddress[]

  @@index([customerId])
  @@map("cart_sessions")
}

/// Normalized row mirroring client `UnifiedCartLine` snapshots for server orchestration + future reporting.
model CartItem {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId           String      @map("session_id") @db.Uuid
  session             CartSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lineId              String      @map("line_id")
  kind                String      @map("kind")
  quantity            Int
  payload             Json
  squareCatalogItemId String?     @map("square_catalog_item_id")
  squareVariationId   String?     @map("square_variation_id")
  fulfillmentPipeline String      @map("fulfillment_pipeline")

  @@unique([sessionId, lineId])
  @@index([sessionId])
  @@map("cart_items")
}

/// Platform order shell — distinct from legacy `CafeOrder` until checkout merges onto one pipeline.
model CommerceOrder {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  status               String    @default("draft")
  customerId           String?   @map("customer_id") @db.Uuid
  customer             Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestCartToken       String?   @map("guest_cart_token")
  totalCents           Int       @map("total_cents")
  kitchenSubtotalCents Int       @default(0) @map("kitchen_subtotal_cents")
  retailSubtotalCents  Int       @default(0) @map("retail_subtotal_cents")
  metadata             Json?

  items               CommerceOrderItem[]
  fulfillmentGroups   FulfillmentGroup[]
  payments            PaymentRecord[]
  emailThreads        EmailThread[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("commerce_orders")
}

model CommerceOrderItem {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId             String        @map("order_id") @db.Uuid
  order               CommerceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kind                String        @map("kind")
  title               String        @map("title")
  quantity            Int
  unitPriceCents      Int           @map("unit_price_cents")
  payload             Json?
  squareCatalogItemId String?       @map("square_catalog_item_id")
  squareVariationId   String?       @map("square_variation_id")
  fulfillmentPipeline String        @map("fulfillment_pipeline")

  fulfillmentLinks FulfillmentItem[]

  @@index([orderId])
  @@map("commerce_order_items")
}

model FulfillmentGroup {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String            @map("order_id") @db.Uuid
  order             CommerceOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pipeline          String            @map("pipeline")
  status            String            @default("pending") @map("status")
  estimatedReadyAt  DateTime?         @map("estimated_ready_at") @db.Timestamptz(6)
  pickupWindowId    String?           @map("pickup_window_id") @db.Uuid
  pickupWindow      PickupWindow?     @relation(fields: [pickupWindowId], references: [id], onDelete: SetNull)

  items     FulfillmentItem[]
  /// Manual carrier tracking — one active row typical per retail ship group; storefront quotes persist on `Shipment`.
  shipments Shipment[]

  @@index([orderId])
  @@map("fulfillment_groups")
}

/// Operational outbound shipment — tied to `FulfillmentGroup` (retail / ship flows).
model Shipment {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  fulfillmentGroupId String             @map("fulfillment_group_id") @db.Uuid
  fulfillmentGroup   FulfillmentGroup   @relation(fields: [fulfillmentGroupId], references: [id], onDelete: Cascade)
  carrier            String?            @map("carrier")
  trackingNumber     String?            @map("tracking_number")
  status             String             @default("pending") @map("status")
  shippedAt          DateTime?          @map("shipped_at") @db.Timestamptz(6)
  notes              String?            @map("notes") @db.Text
  /// Whole cents charged at checkout for this shipment row (storefront quote selection).
  shippingCents      Int?               @map("shipping_cents")
  /// Human-readable carrier service label from the storefront quote (e.g. tier name).
  shippingService    String?            @map("shipping_service")
  /// Carrier rate object id used to purchase a label (expires ~7 days per carrier API rules).
  selectedShippoRateId String?        @map("selected_shippo_rate_id")
  metadata           Json?

  @@index([fulfillmentGroupId])
  @@map("shipments")
}

model FulfillmentItem {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId     String             @map("group_id") @db.Uuid
  group       FulfillmentGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemId String             @map("order_item_id") @db.Uuid
  orderItem   CommerceOrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([groupId, orderItemId])
  @@map("fulfillment_items")
}

model ProductCache {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squareCatalogItemId String   @unique @map("square_catalog_item_id")
  squareCategoryId    String?  @map("square_category_id")
  slug                String?  @map("slug")
  title               String   @map("title")
  description         String?  @map("description") @db.Text
  primaryImageUrl     String?  @map("primary_image_url")
  isAvailable         Boolean  @default(true) @map("is_available")
  data                Json
  syncedAt            DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  variants ProductVariantCache[]

  @@map("product_cache")
}

model ProductVariantCache {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productCacheId    String       @map("product_cache_id") @db.Uuid
  product           ProductCache @relation(fields: [productCacheId], references: [id], onDelete: Cascade)
  squareVariationId String       @unique @map("square_variation_id")
  sku               String?      @map("sku")
  priceCents        Int?         @map("price_cents")
  quantityOnHand    Int?         @map("quantity_on_hand")
  inventoryUpdatedAt DateTime?   @map("inventory_updated_at") @db.Timestamptz(6)
  data              Json?
  syncedAt          DateTime     @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([productCacheId])
  @@map("product_variant_cache")
}

/// Single-row Square Store sync bookkeeping (production catalog — category “Store”).
model CatalogSyncState {
  id                    String    @id @default("singleton")
  storeCategorySquareId String?   @map("store_category_square_id")
  lastFullSyncAt        DateTime? @map("last_full_sync_at") @db.Timestamptz(6)
  lastSyncStats         Json?     @map("last_sync_stats")
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("catalog_sync_state")
}

model PickupWindow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label       String   @map("label")
  pipeline    String   @default("KITCHEN") @map("pipeline")
  startsAt    DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime @map("ends_at") @db.Timestamptz(6)
  capacity    Int?     @map("capacity")

  fulfillmentGroups FulfillmentGroup[]

  @@map("pickup_windows")
}

model ShippingAddress {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  customerId    String?      @map("customer_id") @db.Uuid
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cartSessionId String?      @map("cart_session_id") @db.Uuid
  cartSession   CartSession? @relation(fields: [cartSessionId], references: [id], onDelete: SetNull)
  line1         String       @map("line1")
  line2         String?      @map("line2")
  city          String       @map("city")
  state         String       @map("state")
  postalCode    String       @map("postal_code")
  country       String       @default("US") @map("country")

  @@index([customerId])
  @@map("shipping_addresses")
}

model PaymentRecord {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  orderId         String?        @map("order_id") @db.Uuid
  order           CommerceOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  provider        String         @default("square") @map("provider")
  squarePaymentId String?        @map("square_payment_id")
  squarePaymentStatus String?    @map("square_payment_status")
  amountCents     Int            @map("amount_cents")
  currency        String         @default("USD") @map("currency")
  status          String         @default("pending") @map("status")
  idempotencyKey  String?        @unique @map("idempotency_key")
  capturedAt      DateTime?      @map("captured_at") @db.Timestamptz(6)
  failureReason   String?        @map("failure_reason") @db.Text
  metadata        Json?

  @@index([orderId])
  @@index([squarePaymentId])
  @@map("payment_records")
}

/// Fulfillment-aware outbound/inbound communication threads (Resend + platform-owned).
model EmailThread {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  customerId         String?   @map("customer_id") @db.Uuid
  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  commerceOrderId    String?   @map("commerce_order_id") @db.Uuid
  commerceOrder      CommerceOrder? @relation(fields: [commerceOrderId], references: [id], onDelete: SetNull)
  cafeOrderId        String?   @map("cafe_order_id") @db.Uuid
  subjectSnapshot    String?   @map("subject_snapshot") @db.Text
  providerThreadKey  String?   @unique @map("provider_thread_key")

  messages EmailMessage[]
  links    OrderMessageLink[]
  participants ConversationParticipant[]

  @@index([customerId])
  @@index([commerceOrderId])
  @@map("email_threads")
}

model EmailMessage {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  threadId             String      @map("thread_id") @db.Uuid
  thread               EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction            String      @map("direction")
  fromEmail            String      @map("from_email")
  toEmails             Json        @map("to_emails")
  subject              String?     @map("subject") @db.Text
  textBody             String?     @map("text_body") @db.Text
  htmlBody             String?     @map("html_body") @db.Text
  providerMessageId    String?     @unique @map("provider_message_id")
  rfcMessageId         String?     @map("rfc_message_id")
  inReplyTo           String?     @map("in_reply_to") @db.Text
  referencesHeader     String?     @map("references_header") @db.Text
  fulfillmentGroupId   String?     @map("fulfillment_group_id") @db.Uuid
  deliveryStatus       String      @default("queued") @map("delivery_status")
  rawPayload           Json?       @map("raw_payload")

  links OrderMessageLink[]

  @@index([threadId])
  @@map("email_messages")
}

/// Links messages to orders / fulfillment groups for operational UI later.
model OrderMessageLink {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId           String        @map("message_id") @db.Uuid
  message             EmailMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  threadId            String        @map("thread_id") @db.Uuid
  thread              EmailThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  orderKind           String        @map("order_kind")
  orderId             String        @map("order_id") @db.Uuid
  fulfillmentGroupId  String?       @map("fulfillment_group_id") @db.Uuid

  @@index([orderKind, orderId])
  @@map("order_message_links")
}

/// Maps customers ↔ threads for multi-thread customer service views.
model ConversationParticipant {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId   String      @map("customer_id") @db.Uuid
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  threadId     String      @map("thread_id") @db.Uuid
  thread       EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role         String      @default("customer") @map("role")

  @@unique([customerId, threadId])
  @@index([threadId])
  @@map("conversation_participants")
}

/// Append-only audit trail for orchestration / notification triggers.
model NotificationEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  type        String    @map("type")
  payload     Json      @map("payload")
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@map("notification_events")
}

enum OperationalActivitySeverity {
  info
  warning
  error
  critical
}

/** Product-facing operational activity timeline (distinct from governance audit). */
model OperationalActivityEvent {
  id        String                       @id @default(cuid())
  type      String
  severity  OperationalActivitySeverity
  actorType String                       @map("actor_type")
  actorId   String?                      @map("actor_id")
  actorName String?                      @map("actor_name")
  message   String
  metadata  Json?                        @map("metadata")
  source    String?                      @map("source")
  createdAt DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([type], map: "operational_activity_events_type_idx")
  @@index([createdAt(sort: Desc)], map: "operational_activity_events_created_at_idx")
  @@map("operational_activity_events")
}

/// Platform-detected operational incidents (fed by `OperationalActivityEvent` rules).
model OperationalIncident {
  id              String    @id @default(cuid())
  type            String
  /// `info` | `warning` | `high` | `critical`
  severity        String
  /// `active` | `investigating` | `monitoring` | `resolved`
  status          String
  title           String
  description     String?
  affectedSystems String[]  @default([]) @map("affected_systems")
  firstDetectedAt DateTime? @map("first_detected_at") @db.Timestamptz(6)
  lastDetectedAt  DateTime? @map("last_detected_at") @db.Timestamptz(6)
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz(6)
  metadata        Json?
  /// JSON array of contributing `OperationalActivityEvent` ids
  sourceEventIds  Json?     @map("source_event_ids")
  resolutionNotes String?   @map("resolution_notes")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([type], map: "operational_incidents_type_idx")
  @@index([status], map: "operational_incidents_status_idx")
  @@index([lastDetectedAt(sort: Desc)], map: "operational_incidents_last_detected_at_idx")
  @@map("operational_incidents")
}

/**
 * Latest measured integration reachability per system (`system_key` is unique — one row per integration).
 * Status values: `healthy` | `degraded` | `offline` | `unknown`.
 */
model IntegrationHealthSnapshot {
  id                    String    @id @default(cuid())
  systemKey             String    @unique @map("system_key")
  category              String    @map("category")
  currentStatus         String    @map("current_status")
  latencyMs             Int?      @map("latency_ms")
  failureRate           Float?    @map("failure_rate")
  lastSuccessfulCheckAt DateTime? @map("last_successful_check_at") @db.Timestamptz(6)
  lastFailedCheckAt     DateTime? @map("last_failed_check_at") @db.Timestamptz(6)
  lastErrorMessage      String?   @map("last_error_message") @db.VarChar(500)
  metadata              Json?     @map("metadata")
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("integration_health_snapshots")
}

/**
 * Authenticated browser presence — driven only by real `/api/presence/heartbeat` writes.
 * Guest/anonymous sessions are intentionally out of scope for MVP.
 */
model PlatformPresenceSession {
  id               String    @id @default(cuid())
  sessionPublicId  String    @unique @map("session_public_id")
  cognitoSub       String?   @map("cognito_sub")
  /// `customer` | `admin` | `super_admin` — `guest` reserved for a future anonymous path (not written today).
  userType         String    @map("user_type")
  userRole         String?   @map("user_role")
  displayName      String?   @map("display_name") @db.VarChar(320)
  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  lastActivityAt   DateTime  @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  currentRoute     String?   @map("current_route") @db.VarChar(512)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  /// Updated by heartbeat; rows also evaluated against `lastActivityAt` when displaying “active”.
  isActive         Boolean   @default(true) @map("is_active")
  isImpersonated   Boolean   @default(false) @map("is_impersonated")
  impersonatorSub  String?   @map("impersonator_sub")
  terminatedAt     DateTime? @map("terminated_at") @db.Timestamptz(6)

  @@index([cognitoSub], map: "platform_presence_sessions_cognito_sub_idx")
  @@index([lastActivityAt(sort: Desc)], map: "platform_presence_sessions_last_activity_at_idx")
  @@map("platform_presence_sessions")
}

/** Append-only governance / impersonation audit stream (distinct from `OperationalActivityEvent`). */
model GovernanceAuditEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actionType  String   @map("action_type")
  category    String?  @map("category")
  actorId     String   @map("actor_id")
  actorName   String   @map("actor_name")
  actorRole   String?  @map("actor_role")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  targetName  String?  @map("target_name")
  description String?
  metadata    Json?    @map("metadata")
  reason      String?  @map("reason")
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([actionType], map: "governance_audit_events_action_type_idx")
  @@map("governance_audit_events")
}

/**
 * Append-only–friendly support impersonation ledger (ended rows retained).
 * Rows with **`endedAt: null`** are active within the product’s support UX.
 */
model ImpersonationSupportSession {
  id              String    @id @default(cuid())
  /// Correlate with `momos_presence_sid` when present at start, else a fresh UUID.
  sessionPublicId String    @unique @map("session_public_id")
  actorSub        String    @map("actor_sub")
  actorEmail      String    @map("actor_email") @db.VarChar(320)
  targetSub       String?   @map("target_sub") @db.VarChar(128)
  targetEmail     String    @map("target_email") @db.VarChar(320)
  /// `customer` | `admin` (admin routing is not wired yet — see impersonation start handler).
  scope           String    @map("scope")
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt         DateTime? @map("ended_at") @db.Timestamptz(6)
  ipAddress       String?   @map("ip_address") @db.VarChar(64)
  userAgent       String?   @map("user_agent") @db.VarChar(512)

  @@index([actorSub, endedAt], map: "impersonation_support_sessions_actor_ended_idx")
  @@index([startedAt(sort: Desc)], map: "impersonation_support_sessions_started_at_idx")
  @@map("impersonation_support_sessions")
}
