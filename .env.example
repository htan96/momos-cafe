# Copy to .env or .env.production on the server (never commit real secrets).

# Prisma + PostgreSQL
DATABASE_URL="postgresql://momos_user:CHANGE_ME@127.0.0.1:5432/momos_prod"

# Square (server + client)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production

# Optional: Next binds PORT; must match ecosystem.config.cjs and nginx proxy_pass
# PORT=3000
