# Database
DATABASE_URL=

# Customer magic-link sessions (separate from OPS_SESSION)
CUSTOMER_SESSION_SECRET=
# Optional extra entropy mixed into HMAC key material
CUSTOMER_SESSION_PEPPER=

# Public base URL for magic links (fallback: NEXT_PUBLIC_SITE_URL)
AUTH_PUBLIC_BASE_URL=
NEXT_PUBLIC_SITE_URL=

# Resend (server-only — never expose RESEND_API_KEY client-side)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Ops console session + bootstrap admin (password via OPS_ADMIN_PASSWORD_HASH)
OPS_SESSION_SECRET=
OPS_ADMIN_EMAIL=
OPS_ADMIN_PASSWORD_HASH=
# Comma-separated extra emails allowed to use password step at /login
OPS_PASSWORD_LOGIN_EMAILS=

# Internal APIs
INTERNAL_API_SECRET=

# ── AWS Cognito (central IdP skeleton; see lib/auth/cognito/README.ts comments) ──
# Cognito console → User pools → your pool
COGNITO_REGION=
COGNITO_USER_POOL_ID=
# Cognito console → User pools → App integration → App clients (prefer public SPA + PKCE; omit secret when unused)
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
# Cognito console → Federated identities → Identity pools (reserved for STS / future Amplify-like wiring)
COGNITO_IDENTITY_POOL_ID=
# App integration → Domain — value only, e.g. myapp.auth.us-west-2.amazoncognito.com (no https://)
COGNITO_HOSTED_UI_DOMAIN=
# App client → Hosted UI: allowed callback / sign-out URLs for OAuth / Hosted UI flows
COGNITO_OAUTH_REDIRECT_URI=
COGNITO_OAUTH_LOGOUT_URI=
# Comma-separated path prefixes enforced in middleware (empty string disables). Default in code: /portal
COGNITO_PROTECTED_PREFIXES=
# When "false", callers should treat MFA challenges as blocking until RespondToAuthChallenge is implemented
COGNITO_MFA_OPTIONAL=true
